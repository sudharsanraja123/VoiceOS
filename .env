# VoiceOS Environment Configuration
# Copy to .env and adjust values: cp .env.example .env

# Core
VOICEOS_ENV=development
LOG_LEVEL=INFO
VOICEOS_WORKSPACE=./workspace

# LLM (local Ollama or GGUF)
LLM_ENDPOINT=http://localhost:11434/api/generate
LLM_MODEL=llama3
MODELS_DIRECTORY=./models
MAX_RAM_THRESHOLD=12

# Speech
WHISPER_MODEL=base
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
TTS_OUTPUT_PATH=./output/response.wav
MICROPHONE_DEVICE=default

# Optional cloud API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Security
PERMISSION_LEVEL=medium
SANDBOX_ENABLED=true

# Distributed execution (Phase 6)
REDIS_URL=redis://localhost:6379/0
EXECUTION_MODE=local

# Web UI
WEB_PORT=8000
