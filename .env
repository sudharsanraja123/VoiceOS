# VoiceOS Configuration File
# Copy this file to .env and modify as needed

# LLM Configuration
LLM_ENDPOINT=http://localhost:11434/api/generate
LLM_MODEL=mistral

# TTS Configuration
TTS_OUTPUT_PATH=output/response.wav
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC

# STT Configuration
WHISPER_MODEL=base

# Model Management
MODELS_DIRECTORY=models
MAX_RAM_THRESHOLD=12

# Logging
LOG_LEVEL=INFO

# Hardware Detection (auto-detected, can be overridden)
# RAM_GB=16
# CPU_CORES=8
